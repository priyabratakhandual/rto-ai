						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/chat",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"chat"
					]
				},
				"description": "Chat with the RAG chatbot"
